{
  "version": "1.0",
  "description": "SmartDrive Commands for Indicator Board",
  "device": "IndicatorBoard",
  "typeShift": 0,
  "commands": [
    {
      "id": 1,
      "name": "OLED_PRINT_STR",
      "description": "Print string on OLED at specified position",
      "acknowledges": false,
      "params": [
        {
          "name": "x",
          "type": "UINT16",
          "required": true,
          "description": "X coordinate (pixels)"
        },
        {
          "name": "y",
          "type": "UINT16",
          "required": true,
          "description": "Y coordinate (pixels)"
        },
        {
          "name": "text",
          "type": "STRING",
          "required": true,
          "maxLength": 15,
          "description": "Text to display"
        }
      ]
    },
    {
      "id": 2,
      "name": "OLED_DRAW_FRAME",
      "description": "Draw a rectangular frame on OLED",
      "acknowledges": false,
      "params": [
        {
          "name": "x",
          "type": "UINT16",
          "required": true,
          "description": "X coordinate (pixels)"
        },
        {
          "name": "y",
          "type": "UINT16",
          "required": true,
          "description": "Y coordinate (pixels)"
        },
        {
          "name": "width",
          "type": "UINT16",
          "required": true,
          "description": "Frame width (pixels)"
        }
      ]
    },
    {
      "id": 3,
      "name": "OLED_DRAW_BAR",
      "description": "Draw a progress bar on OLED",
      "acknowledges": false,
      "params": [
        {
          "name": "x",
          "type": "UINT16",
          "required": true,
          "description": "X coordinate (pixels)"
        },
        {
          "name": "y",
          "type": "UINT16",
          "required": true,
          "description": "Y coordinate (pixels)"
        },
        {
          "name": "percent",
          "type": "UINT8",
          "required": true,
          "description": "Fill percentage (0-100)"
        }
      ]
    },
    {
      "id": 4,
      "name": "OLED_CLEAR",
      "description": "Clear the OLED display buffer",
      "acknowledges": false,
      "params": []
    },
    {
      "id": 5,
      "name": "OLED_REFRESH",
      "description": "Send buffer to OLED display (update screen)",
      "acknowledges": false,
      "params": []
    },
    {
      "id": 6,
      "name": "OLED_SET_BRIGHTNESS",
      "description": "Set OLED display brightness",
      "acknowledges": true,
      "params": [
        {
          "name": "brightness",
          "type": "UINT8",
          "required": true,
          "description": "Brightness level (0-255)"
        }
      ]
    },
    {
      "id": 7,
      "name": "LED_SET_BLOCK",
      "description": "Set all LEDs to the same color (RGB565 format)",
      "acknowledges": false,
      "params": [
        {
          "name": "color",
          "type": "UINT16",
          "required": true,
          "description": "RGB565 color value (5-bit R, 6-bit G, 5-bit B)"
        }
      ]
    },
    {
      "id": 8,
      "name": "LED_SET_SINGLE",
      "description": "Set a single LED to specified color (RGB565 format)",
      "acknowledges": false,
      "params": [
        {
          "name": "index",
          "type": "UINT16",
          "required": true,
          "description": "LED index (0-based)"
        },
        {
          "name": "color",
          "type": "UINT16",
          "required": true,
          "description": "RGB565 color value"
        }
      ]
    },
    {
      "id": 9,
      "name": "BEEP",
      "description": "Sound the buzzer for specified duration",
      "acknowledges": false,
      "params": [
        {
          "name": "duration",
          "type": "UINT16",
          "required": true,
          "description": "Beep duration in milliseconds"
        }
      ]
    },
    {
      "id": 10,
      "name": "RESET",
      "description": "Reset hardware subsystems",
      "acknowledges": true,
      "params": [
        {
          "name": "mode",
          "type": "UINT8",
          "required": true,
          "description": "Reset mode: 0=OLED, 1=LEDs, 2=Both"
        }
      ]
    },
    {
      "id": 11,
      "name": "OLED_SET_FONT",
      "description": "Set OLED font from preset",
      "acknowledges": true,
      "params": [
        {
          "name": "font_id",
          "type": "UINT8",
          "required": true,
          "description": "Font preset: 0=small, 1=medium, 2=large"
        }
      ]
    },
    {
      "id": 12,
      "name": "OLED_SET_CURSOR",
      "description": "Set cursor position for next print",
      "acknowledges": false,
      "params": [
        {
          "name": "x",
          "type": "UINT16",
          "required": true,
          "description": "X coordinate"
        },
        {
          "name": "y",
          "type": "UINT16",
          "required": true,
          "description": "Y coordinate"
        }
      ]
    },
    {
      "id": 13,
      "name": "SEND_ID",
      "description": "Send ID with protocol revision and slave capabilities to STM32",
      "acknowledges": true,
      "params": [
        {
          "name": "id",
          "type": "UINT8",
          "required": true,
          "description": "ID to send"
        },
        {
          "name": "protocol_revision",
          "type": "UINT8",
          "required": true,
          "description": "Protocol Revision"
        },
        {
          "name": "slave_capabilities",
          "type": "UINT16",
          "required": true,
          "description": "Slave capabilities"
        }
      ]
    },
    {
      "id": 14,
      "name": "DISCOVERY",
      "description": "Broadcast by master at startup to all slave slots. Each responding slave replies with SEND_ID carrying its id, protocol_revision, and slave_capabilities. Master uses responses to populate the presence map.",
      "acknowledges": false,
      "params": []
    },
    {
      "id": 15,
      "name": "TURNON_BUILTIN_LED",
      "description": "Turn on the built-in LED on the Indicator Board",
      "acknowledges": false,
      "params": []
    },
    {
      "id": 16,
      "name": "TURNOFF_BUILTIN_LED",
      "description": "Turn off the built-in LED on the Indicator Board",
      "acknowledges": false,
      "params": []
    }
  ],
  "telemetry": [
    {
      "id": 1,
      "name": "DISPLAY_BRIGHTNESS",
      "description": "Current OLED brightness level (0-255)",
      "type": "UINT8"
    },
    {
      "id": 2,
      "name": "LED_COUNT",
      "description": "Number of active LEDs currently lit",
      "type": "UINT16"
    }
  ],
  "settings": [
    {
      "id": 1,
      "name": "OLED_BRIGHTNESS",
      "description": "Default OLED brightness on startup (0-255)",
      "type": "UINT8"
    },
    {
      "id": 2,
      "name": "OLED_CONTRAST",
      "description": "Default OLED contrast on startup (0-255)",
      "type": "UINT8"
    },
    {
      "id": 3,
      "name": "DEFAULT_FONT",
      "description": "Default font preset on startup (0=small, 1=medium, 2=large)",
      "type": "UINT8"
    },
    {
      "id": 4,
      "name": "LED_DEFAULT_COLOR",
      "description": "Default LED color on startup (RGB565 format)",
      "type": "UINT16"
    },
    {
      "id": 5,
      "name": "BUZZER_ENABLED",
      "description": "Whether the buzzer is enabled (0=disabled, 1=enabled)",
      "type": "UINT8"
    }
  ]
}